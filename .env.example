# Booming Tech — Environment Variables Template
# Copy to .env and fill with REAL values. .env is gitignored.
# All keys marked REQUIRED will cause the server to FAIL CLOSED at startup
# if missing or set to a known placeholder value (see docs/secrets-rotation.md).
#
# Generate SESSION_SECRET with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
# Generate CRON_TOKEN with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

# ===== Server =====
PORT=15000

# ===== Session signing (REQUIRED, fail-closed) =====
# Must be at least 32 chars. Server refuses to start with placeholder values.
SESSION_SECRET=CHANGE_ME_generate_a_48_byte_base64_string

# ===== Cron endpoint auth (REQUIRED, fail-closed) =====
# Header X-CRON_TOKEN must match. Used by /api/cron/* endpoints.
CRON_TOKEN=CHANGE_ME_generate_a_32_byte_hex_string

# ===== PayPal webhook (REQUIRED for production) =====
# Get from PayPal dashboard → Webhooks → your webhook URL.
PAYPAL_WEBHOOK_ID=

# ===== MySQL (REQUIRED) =====
DB_HOST=localhost
DB_PORT=3306
DB_USER=booming
DB_PASSWORD=CHANGE_ME_use_a_strong_random_password
DB_NAME=booming

# ===== DB copy target whitelist (optional) =====
# Comma-separated list of allowed MySQL hosts for /api/db-copy.
# If unset, only the current DB_HOST is allowed.
# DB_COPY_ALLOWED_HOSTS=backup.example.com,10.0.0.5
